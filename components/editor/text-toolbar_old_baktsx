      <div className="flex items-center gap-1">
        
        {/* 1. FONT WEIGHT SLIDER */}
        <Popover>
          <PopoverTrigger asChild>
            <Button variant="ghost" size="icon" className="h-9 w-9 hover:bg-slate-100 rounded-xl">
